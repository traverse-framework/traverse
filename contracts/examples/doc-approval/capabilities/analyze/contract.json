  },
  "summary": "Analyze a submitted document into deterministic approval-review fields.",
  "description": "Portable deterministic document approval analysis capability used by doc-approval reference clients. It extracts flat UI-facing fields without model, network, randomness, or host state dependencies.",
  "inputs": {
    "schema": {
      "type": "object",
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "outputs": {
    "schema": {
      "type": "object",
      "required": [
        "docType",
        "parties",
        "amounts",
        "confidence",
        "recommendation"
      ],
      "properties": {
        "docType": {
          "type": "string"
        },
        "parties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "amounts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "preconditions": [
    {
      "id": "document-provided",
      "description": "The caller provides a document string to analyze."
    }
  ],
  "postconditions": [
    {
      "id": "analysis-fields-produced",
      "description": "The capability returns deterministic document type, parties, amounts, confidence, and recommendation fields."
    }
  ],
  "side_effects": [
    {
      "kind": "memory_only",
      "description": "Produces one deterministic analysis payload for the provided document."
    }
  ],
  "emits": [],
  "consumes": [],
  "permissions": [
    {
      "id": "doc-approval.analyze"
    }
  ],
  "execution": {
    "binary_format": "wasm",
    "entrypoint": {
      "kind": "wasi-command",
      "command": "run"
    },
    "preferred_targets": [
      "local"
    ],
    "constraints": {
      "host_api_access": "none",
      "network_access": "forbidden",
      "filesystem_access": "none"
    }
  },

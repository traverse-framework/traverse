      ],
      "properties": {
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "outputs": {
    "schema": {
      "type": "object",
      "required": [
        "validate",
        "process",
        "summarize"
      ],
      "properties": {
        "validate": {
          "type": "object"
        },
        "process": {
          "type": "object"
        },
        "summarize": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "preconditions": [
    {
      "id": "note-provided",
      "description": "The caller provides one starter note string for the pipeline."
    }
  ],
  "postconditions": [
    {
      "id": "merged-pipeline-output-produced",
      "description": "The pipeline returns the validate, process, and summarize step outputs merged under namespaced keys."
    }
  ],
  "side_effects": [
    {
      "kind": "state_change",
      "description": "Executes the approved traverse-starter pipeline workflow across the three atomic capabilities."
    }
  ],

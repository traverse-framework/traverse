{
  "kind": "capability_contract",
  "schema_version": "1.0.0",
  "id": "traverse-starter.validate",
  "namespace": "traverse-starter",
  "name": "validate",
  "version": "1.0.0",
  "lifecycle": "active",
  "owner": {
    "team": "traverse-core",
    "contact": "enrico.piovesan10@gmail.com"
  },
  "summary": "Validate one starter note deterministically before pipeline processing.",
  "description": "Reference app capability for the traverse-starter multi-capability pipeline showcase (spec 058-workflow-pipeline-execution). Reports a deterministic verdict without model inference: an empty or whitespace-only note yields valid=false with a non-empty issues list, and a note longer than 2000 characters is reported as an issue.",
  "inputs": {
    "schema": {
      "type": "object",
      "required": [
        "note"
      ],
      "properties": {
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "outputs": {
    "schema": {
      "type": "object",
      "required": [
        "valid",
        "issues"
      ],
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "preconditions": [
    {
      "id": "note-field-present",
      "description": "The caller provides a note string field; emptiness is reported as a validation issue rather than an execution error."
    }
  ],
  "postconditions": [
    {
      "id": "validation-verdict-produced",
      "description": "The capability returns valid=true with an empty issues list exactly when the note passes every deterministic validation rule."
    }
  ],
  "side_effects": [
    {
      "kind": "memory_only",
      "description": "Produces a deterministic validation verdict from the provided input."
    }
  ],
  "emits": [],
  "consumes": [],
  "permissions": [
    {
      "id": "traverse-starter.validate"
    }
  ],
  "execution": {
    "binary_format": "wasm",
    "entrypoint": {
      "kind": "wasi-command",
      "command": "run"
    },
    "preferred_targets": [
      "local"
    ],
    "constraints": {
      "host_api_access": "none",
      "network_access": "forbidden",
      "filesystem_access": "none"
    }
  },
  "policies": [
    {
      "id": "manual-approval-required"
    }
  ],
  "dependencies": [],
  "provenance": {
    "source": "greenfield",
    "author": "enricopiovesan",
    "created_at": "2026-07-08T00:00:00Z",
    "spec_ref": "058-workflow-pipeline-execution@1.0.0",
    "adr_refs": [
      "0001-rust-wasm-foundation"
    ],
    "exception_refs": []
  },
  "evidence": [],
  "service_type": "stateless",
  "permitted_targets": [
    "local",
    "cloud",
    "edge",
    "device"
  ],
  "artifact_type": "native"
}

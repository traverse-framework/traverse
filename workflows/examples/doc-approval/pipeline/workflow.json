{
  "kind": "workflow_definition",
  "schema_version": "1.0.0",
  "id": "doc-approval.pipeline",
  "name": "pipeline",
  "version": "1.0.0",
  "lifecycle": "active",
  "owner": {
    "team": "traverse-core",
    "contact": "enrico.piovesan10@gmail.com"
  },
  "summary": "Canonical doc-approval pipeline: analyze one document, then produce the deterministic approval recommendation. No extract step (spec 069).",
  "inputs": {
    "schema": {
      "type": "object",
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "outputs": {
    "schema": {
      "type": "object",
      "required": [
        "analysis",
        "recommendation"
      ],
      "properties": {
        "analysis": {
          "type": "object"
        },
        "recommendation": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "nodes": [
    {
      "node_id": "analyze_document",
      "capability_id": "doc-approval.analyze",
      "capability_version": "1.0.0",
      "input": {
        "from_workflow_input": [
          "document"
        ]
      },
      "output": {
        "to_workflow_state": [
          "docType",
          "parties",
          "amounts",
          "confidence",
          "recommendation"
        ],
        "publish_to_state_as": "analysis"
      }
    },
    {
      "node_id": "recommend_document",
      "capability_id": "doc-approval.recommend",
      "capability_version": "1.0.0",
      "input": {
        "from_workflow_input": [
          "docType",
          "parties",
          "amounts",
          "confidence",
          "recommendation"
        ]
      },
      "output": {
        "to_workflow_state": [],
        "publish_to_state_as": "recommendation"
      }
    }
  ],
  "edges": [
    {
      "edge_id": "analyze_to_recommend",
      "from": "analyze_document",
      "to": "recommend_document",
      "trigger": "direct"
    }
  ],
  "start_node": "analyze_document",
  "terminal_nodes": [
    "recommend_document"
  ],
  "output_projection": [
    "analysis",
    "recommendation"
  ],
  "tags": [
    "doc-approval",
    "pipeline",
    "reference-app",
    "deterministic"
  ],
  "governing_spec": "007-workflow-registry-traversal"
}

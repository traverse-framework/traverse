  "summary": "Run the doc-approval extract, analyze, and recommend pipeline as one governed capability.",
  "description": "Workflow-backed capability for the doc-approval multi-capability pipeline showcase (spec 058-workflow-pipeline-execution). A single execute call runs extract, analyze, and recommend sequentially and returns their outputs merged under namespaced keys. The step agents are delivered by their own tickets (#538 extract, #556 analyze, #555 recommend); the pipeline registers once those capabilities exist in the workspace.",
  "inputs": {
    "schema": {
      "type": "object",
      "required": [
        "document"
      ],
      "properties": {
        "document": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "outputs": {
    "schema": {
      "type": "object",
      "required": [
        "extract",
        "analyze",
        "recommend"
      ],
      "properties": {
        "extract": {
          "type": "object"
        },
        "analyze": {
          "type": "object"
        },
        "recommend": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "preconditions": [
    {
      "id": "document-provided",
      "description": "The caller provides one document string for the pipeline."
    }
  ],
  "postconditions": [
    {
      "id": "merged-pipeline-output-produced",
      "description": "The pipeline returns the extract, analyze, and recommend step outputs merged under namespaced keys."
    }
  ],
  "side_effects": [
    {
      "kind": "state_change",
      "description": "Executes the approved doc-approval pipeline workflow across the three atomic capabilities."
    }
  ],
  "emits": [],
  "consumes": [],
